.DS_Store
.netlify/
node_modules/
.superpowers/
.playwright-mcp/
.playwright-cli/
.unlighthouse/
output/
*.png
# ...but EVERY PWA / apple-touch / startup / screenshot PNG in public/ MUST
# deploy (Netlify builds from git, so blanket-ignoring these 404s the live
# manifest icons, iOS startup images, and install-dialog screenshots).
# Directory-level negation so new public deploy PNGs are never missed again.
!app/public/*.png
!app/public/examples/audit/og-image.png
*.bak
docs/
firebase-debug.log
.claude/
node_modules/
package-lock.json
!/package-lock.json
!app/package-lock.json
dist/
dist-*/

# --- secrets & local cruft (added during 2026-06-30 consolidation) ---
.env
*.env
.env.*
app/.env
tmp/
backup/
deploy-*.zip
*.zip
_qa/
