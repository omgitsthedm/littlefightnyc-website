{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://internal.example.com/schemas/service-business-brief.schema.json",
  "title": "Service Business Website Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "presetId",
    "project",
    "business",
    "conversion",
    "proof",
    "brand",
    "content",
    "compliance",
    "technical",
    "deployment"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "presetId": {
      "type": "string",
      "enum": [
        "local-service",
        "professional-service",
        "clinic-wellness",
        "multi-location-service"
      ]
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "projectId",
        "projectName",
        "status",
        "locale",
        "timezone",
        "revision"
      ],
      "properties": {
        "projectId": {
          "$ref": "#/$defs/slug"
        },
        "projectName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "validated",
            "generated",
            "deployed",
            "needs_revision",
            "approved",
            "archived"
          ]
        },
        "revision": {
          "type": "integer",
          "minimum": 1
        },
        "ownerName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "ownerEmail": {
          "type": "string",
          "format": "email"
        },
        "locale": {
          "type": "string",
          "minLength": 2,
          "maxLength": 16
        },
        "timezone": {
          "type": "string",
          "minLength": 3,
          "maxLength": 64
        },
        "notes": {
          "type": "string",
          "maxLength": 4000
        }
      }
    },
    "business": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "companyName",
        "industry",
        "businessModel",
        "locations",
        "audiences",
        "offerCategories"
      ],
      "properties": {
        "companyName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        },
        "legalName": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "industry": {
          "type": "string",
          "enum": [
            "local_service_business",
            "professional_services",
            "clinic_wellness",
            "home_services",
            "agency_studio",
            "legal_accounting_advisory",
            "hospitality_service_led",
            "multi_location_service_brand"
          ]
        },
        "subIndustry": {
          "type": "string",
          "maxLength": 120
        },
        "businessModel": {
          "type": "string",
          "enum": [
            "single_location",
            "service_area",
            "hybrid",
            "multi_location",
            "franchise"
          ]
        },
        "yearsInBusiness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        },
        "locations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/location"
          }
        },
        "audiences": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/audience"
          }
        },
        "offerCategories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/offerCategory"
          }
        },
        "serviceAreas": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          }
        }
      }
    },
    "conversion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primaryModel",
        "primaryCta",
        "successMetric",
        "handoffPreference"
      ],
      "properties": {
        "primaryModel": {
          "type": "string",
          "enum": [
            "lead_form",
            "booking",
            "phone_call"
          ]
        },
        "secondaryModel": {
          "type": "string",
          "enum": [
            "lead_form",
            "booking",
            "phone_call"
          ]
        },
        "primaryCta": {
          "$ref": "#/$defs/cta"
        },
        "secondaryCta": {
          "$ref": "#/$defs/cta"
        },
        "successMetric": {
          "type": "string",
          "enum": [
            "qualified_lead",
            "quote_request",
            "consultation_request",
            "booked_appointment",
            "phone_call"
          ]
        },
        "handoffPreference": {
          "type": "string",
          "enum": [
            "internal_review",
            "client_review",
            "engineer_export"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 2000
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "proofAvailability",
        "testimonials",
        "caseStudies",
        "stats",
        "certifications",
        "clients"
      ],
      "properties": {
        "proofAvailability": {
          "type": "string",
          "enum": [
            "none",
            "partial",
            "full"
          ]
        },
        "testimonials": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/testimonial"
          }
        },
        "caseStudies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/caseStudy"
          }
        },
        "stats": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stat"
          }
        },
        "certifications": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/certification"
          }
        },
        "clients": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        }
      }
    },
    "brand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "logoAssets",
        "colors",
        "fontPreference",
        "toneKeywords",
        "photoStyle",
        "iconStyle"
      ],
      "properties": {
        "logoAssets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/logoAsset"
          }
        },
        "colors": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primary",
            "secondary",
            "accent",
            "surface",
            "text"
          ],
          "properties": {
            "primary": {
              "$ref": "#/$defs/hexColor"
            },
            "secondary": {
              "$ref": "#/$defs/hexColor"
            },
            "accent": {
              "$ref": "#/$defs/hexColor"
            },
            "surface": {
              "$ref": "#/$defs/hexColor"
            },
            "text": {
              "$ref": "#/$defs/hexColor"
            }
          }
        },
        "fontPreference": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source"
          ],
          "properties": {
            "source": {
              "type": "string",
              "enum": [
                "web_safe",
                "google",
                "custom",
                "undecided"
              ]
            },
            "headingFamily": {
              "type": "string",
              "maxLength": 120
            },
            "bodyFamily": {
              "type": "string",
              "maxLength": 120
            }
          }
        },
        "toneKeywords": {
          "type": "array",
          "minItems": 3,
          "maxItems": 8,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          }
        },
        "bannedToneKeywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 40
          }
        },
        "photoStyle": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode",
            "descriptors"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "original",
                "stock",
                "mixed",
                "undecided"
              ]
            },
            "descriptors": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 60
              }
            }
          }
        },
        "iconStyle": {
          "type": "string",
          "enum": [
            "outline",
            "filled",
            "minimal",
            "rounded",
            "none"
          ]
        }
      }
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hero",
        "about",
        "differentiators",
        "services",
        "faq",
        "contact"
      ],
      "properties": {
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "headline",
            "supportingText",
            "primaryPromise"
          ],
          "properties": {
            "headline": {
              "type": "string",
              "minLength": 8,
              "maxLength": 120
            },
            "supportingText": {
              "type": "string",
              "minLength": 20,
              "maxLength": 300
            },
            "primaryPromise": {
              "type": "string",
              "minLength": 8,
              "maxLength": 140
            },
            "trustBar": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              }
            }
          }
        },
        "about": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "summary"
          ],
          "properties": {
            "summary": {
              "type": "string",
              "minLength": 40,
              "maxLength": 1200
            },
            "founderStory": {
              "type": "string",
              "maxLength": 2000
            }
          }
        },
        "differentiators": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "items": {
            "$ref": "#/$defs/differentiator"
          }
        },
        "services": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/service"
          }
        },
        "faq": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/faqItem"
          }
        },
        "contact": {
          "$ref": "#/$defs/contact"
        }
      }
    },
    "compliance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privacyPolicy",
        "termsOfUse",
        "disclaimers",
        "regulatedIndustry"
      ],
      "properties": {
        "privacyPolicy": {
          "$ref": "#/$defs/policyRef"
        },
        "termsOfUse": {
          "$ref": "#/$defs/policyRef"
        },
        "disclaimers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/disclaimer"
          }
        },
        "regulatedIndustry": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "category",
            "requiresReview",
            "restrictedClaims"
          ],
          "properties": {
            "category": {
              "type": "string",
              "enum": [
                "none",
                "healthcare",
                "legal",
                "financial",
                "advisory",
                "other"
              ]
            },
            "requiresReview": {
              "type": "boolean"
            },
            "restrictedClaims": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 160
              }
            },
            "licenseNumbers": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              }
            },
            "mandatoryFooterText": {
              "type": "string",
              "maxLength": 500
            }
          }
        }
      }
    },
    "technical": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requiredPages",
        "forms",
        "integrations",
        "analytics",
        "seo"
      ],
      "properties": {
        "requiredPages": {
          "type": "array",
          "uniqueItems": true,
          "minItems": 5,
          "items": {
            "type": "string",
            "enum": [
              "home",
              "about",
              "services_index",
              "service_detail",
              "locations_index",
              "location_detail",
              "case_studies",
              "testimonials",
              "faq",
              "contact",
              "privacy",
              "terms"
            ]
          }
        },
        "forms": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/form"
          }
        },
        "integrations": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "crm",
            "scheduling",
            "emailMarketing",
            "maps",
            "chat",
            "reviews"
          ],
          "properties": {
            "crm": {
              "$ref": "#/$defs/integration"
            },
            "scheduling": {
              "$ref": "#/$defs/integration"
            },
            "emailMarketing": {
              "$ref": "#/$defs/integration"
            },
            "maps": {
              "$ref": "#/$defs/integration"
            },
            "chat": {
              "$ref": "#/$defs/integration"
            },
            "reviews": {
              "$ref": "#/$defs/integration"
            }
          }
        },
        "analytics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "ga4Enabled",
            "searchConsoleOwnerVerified",
            "cookieConsentRequired"
          ],
          "properties": {
            "ga4Enabled": {
              "type": "boolean"
            },
            "ga4MeasurementIdRef": {
              "type": "string",
              "maxLength": 120
            },
            "searchConsoleOwnerVerified": {
              "type": "boolean"
            },
            "cookieConsentRequired": {
              "type": "boolean"
            },
            "tagManagerContainerRef": {
              "type": "string",
              "maxLength": 120
            }
          }
        },
        "seo": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "primaryKeyword",
            "secondaryKeywords",
            "targetLocations",
            "serviceAreas",
            "titleTemplate",
            "metaDescriptionGuidance",
            "schemaTypes"
          ],
          "properties": {
            "primaryKeyword": {
              "type": "string",
              "minLength": 3,
              "maxLength": 120
            },
            "secondaryKeywords": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 3,
                "maxLength": 120
              }
            },
            "targetLocations": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 120
              }
            },
            "serviceAreas": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 2,
                "maxLength": 120
              }
            },
            "titleTemplate": {
              "type": "string",
              "minLength": 10,
              "maxLength": 180
            },
            "metaDescriptionGuidance": {
              "type": "string",
              "minLength": 20,
              "maxLength": 240
            },
            "schemaTypes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "enum": [
                  "LocalBusiness",
                  "ProfessionalService",
                  "MedicalBusiness",
                  "LegalService",
                  "Organization",
                  "FAQPage",
                  "BreadcrumbList"
                ]
              }
            }
          }
        }
      }
    },
    "deployment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "previewMode",
        "netlify",
        "gitSource",
        "environmentVariables"
      ],
      "properties": {
        "previewMode": {
          "type": "string",
          "enum": [
            "site_url",
            "deploy_permalink"
          ]
        },
        "netlify": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "teamSlug",
            "siteNamePrefix",
            "reuseSitePerProject",
            "publishDirectory"
          ],
          "properties": {
            "teamSlug": {
              "$ref": "#/$defs/slug"
            },
            "siteNamePrefix": {
              "$ref": "#/$defs/slug"
            },
            "reuseSitePerProject": {
              "type": "boolean"
            },
            "publishDirectory": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "buildCommand": {
              "type": "string",
              "maxLength": 200
            },
            "customPreviewDomain": {
              "type": "string",
              "maxLength": 255
            },
            "siteRulesNotes": {
              "type": "string",
              "maxLength": 1000
            }
          }
        },
        "gitSource": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "mode"
          ],
          "properties": {
            "mode": {
              "type": "string",
              "enum": [
                "manual_zip",
                "git_connected",
                "export_only"
              ]
            },
            "provider": {
              "type": "string",
              "enum": [
                "github",
                "gitlab",
                "bitbucket"
              ]
            },
            "repoOwner": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "repoName": {
              "type": "string",
              "minLength": 1,
              "maxLength": 120
            },
            "defaultBranch": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            }
          },
          "allOf": [
            {
              "if": {
                "required": [
                  "mode"
                ],
                "properties": {
                  "mode": {
                    "const": "git_connected"
                  }
                }
              },
              "then": {
                "required": [
                  "provider",
                  "repoOwner",
                  "repoName",
                  "defaultBranch"
                ]
              }
            }
          ]
        },
        "environmentVariables": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/environmentVariable"
          }
        },
        "previewRecipients": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "email"
          }
        }
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
      "minLength": 2,
      "maxLength": 80
    },
    "phone": {
      "type": "string",
      "pattern": "^\\+?[0-9()\\.\\-\\s]{7,20}$"
    },
    "hexColor": {
      "type": "string",
      "pattern": "^#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6})$"
    },
    "assetRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "assetId",
        "label",
        "kind",
        "url"
      ],
      "properties": {
        "assetId": {
          "$ref": "#/$defs/slug"
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "kind": {
          "type": "string",
          "enum": [
            "logo",
            "photo",
            "document",
            "icon",
            "video"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "cta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "actionType"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 40
        },
        "actionType": {
          "type": "string",
          "enum": [
            "form",
            "booking",
            "phone",
            "url"
          ]
        },
        "formId": {
          "$ref": "#/$defs/slug"
        },
        "phoneNumber": {
          "$ref": "#/$defs/phone"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "note": {
          "type": "string",
          "maxLength": 240
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "actionType"
            ],
            "properties": {
              "actionType": {
                "const": "form"
              }
            }
          },
          "then": {
            "required": [
              "formId"
            ]
          }
        },
        {
          "if": {
            "required": [
              "actionType"
            ],
            "properties": {
              "actionType": {
                "const": "booking"
              }
            }
          },
          "then": {
            "required": [
              "url"
            ]
          }
        },
        {
          "if": {
            "required": [
              "actionType"
            ],
            "properties": {
              "actionType": {
                "const": "phone"
              }
            }
          },
          "then": {
            "required": [
              "phoneNumber"
            ]
          }
        },
        {
          "if": {
            "required": [
              "actionType"
            ],
            "properties": {
              "actionType": {
                "const": "url"
              }
            }
          },
          "then": {
            "required": [
              "url"
            ]
          }
        }
      ]
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locationId",
        "label",
        "city",
        "region",
        "countryCode",
        "isPrimary",
        "publicAddress"
      ],
      "properties": {
        "locationId": {
          "$ref": "#/$defs/slug"
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "address1": {
          "type": "string",
          "maxLength": 160
        },
        "address2": {
          "type": "string",
          "maxLength": 160
        },
        "city": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "region": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "postalCode": {
          "type": "string",
          "maxLength": 30
        },
        "countryCode": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "phone": {
          "$ref": "#/$defs/phone"
        },
        "isPrimary": {
          "type": "boolean"
        },
        "publicAddress": {
          "type": "boolean"
        },
        "serviceAreaLabel": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "audience": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "segment",
        "painPoints",
        "desiredOutcome"
      ],
      "properties": {
        "segment": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "painPoints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 200
          }
        },
        "desiredOutcome": {
          "type": "string",
          "minLength": 4,
          "maxLength": 200
        },
        "journeyStage": {
          "type": "string",
          "enum": [
            "awareness",
            "consideration",
            "decision",
            "retention"
          ]
        }
      }
    },
    "offerCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
