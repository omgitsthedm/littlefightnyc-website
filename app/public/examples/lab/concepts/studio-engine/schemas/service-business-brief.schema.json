          "minLength": 2,
          "maxLength": 120
        },
        "roleOrRelationship": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "direct",
            "google",
            "yelp",
            "clutch",
            "other"
          ]
        }
      }
    },
    "caseStudy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "problem",
        "solution",
        "outcome"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 4,
          "maxLength": 120
        },
        "problem": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "solution": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        },
        "outcome": {
          "type": "string",
          "minLength": 10,
          "maxLength": 500
        }
      }
    },
    "stat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
