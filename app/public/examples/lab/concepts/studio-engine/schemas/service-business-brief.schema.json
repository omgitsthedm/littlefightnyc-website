        "sourceNote"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "value": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "sourceNote": {
          "type": "string",
          "minLength": 2,
          "maxLength": 160
        }
      }
    },
    "certification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "issuer"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "issuer": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "licenseId": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "logoAsset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "asset"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "wordmark",
            "symbol",
            "lockup",
            "light",
            "dark"
          ]
        },
        "asset": {
          "$ref": "#/$defs/assetRef"
        }
      }
    },
    "differentiator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "detail"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80
        },
        "detail": {
          "type": "string",
          "minLength": 12,
          "maxLength": 240
        }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "serviceId",
        "name",
        "summary",
        "outcomes"
      ],
      "properties": {
        "serviceId": {
          "$ref": "#/$defs/slug"
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 400
        },
        "audienceFit": {
          "type": "string",
          "maxLength": 200
        },
        "outcomes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 4,
            "maxLength": 120
          }
        },
        "ctaLabel": {
          "type": "string",
          "maxLength": 40
        }
      }
    },
    "faqItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "question",
        "answer"
      ],
      "properties": {
        "question": {
          "type": "string",
          "minLength": 8,
          "maxLength": 180
        },
        "answer": {
          "type": "string",
          "minLength": 20,
          "maxLength": 800
        }
      }
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "publicEmail",
        "phone",
        "primaryLocationId",
        "businessHours"
      ],
      "properties": {
        "publicEmail": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "$ref": "#/$defs/phone"
        },
        "primaryLocationId": {
          "$ref": "#/$defs/slug"
        },
        "bookingUrl": {
          "type": "string",
          "format": "uri"
        },
        "businessHours": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2,
            "maxLength": 80
          }
        },
        "socialLinks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/socialLink"
          }
        }
      }
    },
    "socialLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "url"
      ],
      "properties": {
        "platform": {
          "type": "string",
          "enum": [
            "facebook",
            "instagram",
            "linkedin",
            "youtube",
            "tiktok",
            "x",
            "other"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "policyRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "provided_url",
            "generate_from_template",
            "not_required"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "notes": {
          "type": "string",
          "maxLength": 500
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "mode"
            ],
            "properties": {
              "mode": {
                "const": "provided_url"
              }
            }
          },
          "then": {
            "required": [
              "url"
            ]
          }
        }
      ]
    },
    "disclaimer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "body",
        "placement"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "body": {
          "type": "string",
          "minLength": 10,
          "maxLength": 800
        },
        "placement": {
          "type": "string",
          "enum": [
            "hero",
            "service_detail",
            "booking",
            "footer",
            "sitewide"
          ]
        }
      }
    },
    "form": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "formId",
        "formType",
        "title",
        "submitLabel",
        "fields"
      ],
      "properties": {
        "formId": {
          "$ref": "#/$defs/slug"
        },
        "formType": {
          "type": "string",
          "enum": [
            "contact",
            "quote_request",
            "consultation",
            "booking_request"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "submitLabel": {
          "type": "string",
          "minLength": 2,
          "maxLength": 40
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/formField"
          }
        }
      }
    },
    "formField": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "label",
        "inputType",
        "required"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/slug"
        },
        "label": {
          "type": "string",
          "minLength": 2,
          "maxLength": 80
        },
        "inputType": {
          "type": "string",
          "enum": [
            "text",
            "email",
            "phone",
            "textarea",
            "select",
            "checkbox"
          ]
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "integration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "maxLength": 120
        },
        "configRef": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "environmentVariable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key",
        "context",
        "visibility"
      ],
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$",
          "maxLength": 120
        },
        "context": {
          "type": "string",
          "enum": [
            "preview",
            "production",
            "all"
          ]
        },
        "visibility": {
          "type": "string",
          "enum": [
            "public",
            "secret"
          ]
        },
        "publicValue": {
          "type": "string",
          "maxLength": 500
        },
        "secretRef": {
          "type": "string",
          "maxLength": 120
        }
      },
      "allOf": [
        {
          "if": {
            "required": [
              "visibility"
            ],
            "properties": {
              "visibility": {
                "const": "public"
              }
            }
          },
          "then": {
            "required": [
              "publicValue"
            ]
          }
        },
        {
          "if": {
            "required": [
              "visibility"
            ],
            "properties": {
              "visibility": {
                "const": "secret"
              }
            }
          },
          "then": {
            "required": [
              "secretRef"
            ]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "conversion"
        ],
        "properties": {
          "conversion": {
            "required": [
              "primaryModel"
            ],
            "properties": {
              "primaryModel": {
                "const": "lead_form"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "conversion": {
            "properties": {
              "primaryCta": {
                "properties": {
                  "actionType": {
                    "const": "form"
                  }
                }
              }
            }
          },
          "technical": {
            "properties": {
              "forms": {
                "minItems": 1
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "conversion"
        ],
        "properties": {
          "conversion": {
            "required": [
              "primaryModel"
            ],
            "properties": {
              "primaryModel": {
                "const": "booking"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "conversion": {
            "properties": {
              "primaryCta": {
                "properties": {
                  "actionType": {
                    "const": "booking"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "conversion"
        ],
        "properties": {
          "conversion": {
            "required": [
              "primaryModel"
            ],
            "properties": {
              "primaryModel": {
                "const": "phone_call"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "conversion": {
            "properties": {
              "primaryCta": {
                "properties": {
                  "actionType": {
                    "const": "phone"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "business"
        ],
        "properties": {
          "business": {
            "required": [
              "businessModel"
            ],
            "properties": {
              "businessModel": {
                "enum": [
                  "multi_location",
                  "franchise"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "business": {
            "properties": {
              "locations": {
                "minItems": 2
              }
            }
          },
          "technical": {
            "properties": {
              "requiredPages": {
                "allOf": [
                  {
                    "contains": {
                      "const": "locations_index"
                    }
                  },
                  {
                    "contains": {
                      "const": "location_detail"
                    }
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "compliance"
        ],
        "properties": {
          "compliance": {
            "required": [
              "regulatedIndustry"
            ],
            "properties": {
              "regulatedIndustry": {
                "required": [
                  "category"
                ],
                "properties": {
                  "category": {
                    "not": {
                      "const": "none"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "compliance": {
            "properties": {
              "disclaimers": {
                "minItems": 1
              },
              "regulatedIndustry": {
                "properties": {
                  "requiresReview": {
                    "const": true
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "proof"
        ],
        "properties": {
          "proof": {
            "required": [
              "proofAvailability"
            ],
            "properties": {
              "proofAvailability": {
                "enum": [
                  "partial",
                  "full"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "proof": {
            "anyOf": [
              {
                "properties": {
                  "testimonials": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "caseStudies": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "stats": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "certifications": {
                    "minItems": 1
                  }
                }
              },
              {
                "properties": {
                  "clients": {
                    "minItems": 1
                  }
                }
              }
            ]
          }
        }
      }
    }
  ]
}
