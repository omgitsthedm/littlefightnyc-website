{
  "prefetch": [
    {
      "where": {
        "and": [
          { "href_matches": "/*" },
          { "not": { "href_matches": "/assets/*" } },
          { "not": { "href_matches": "/*.xml" } },
          { "not": { "href_matches": "/*.txt" } }
        ]
      },
      "eagerness": "moderate"
    }
  ]
}
