{
  "$schema": "https://littlefightnyc.com/brand-kit/assets/color/tokens.schema.json",
  "name": "Little Fight NYC",
  "version": "2.0.0",
  "updated": "2026-07-24",
  "source": "app/src/styles/editorial/tokens.css",
  "color": {
    "background": {
      "value": "#050507",
      "css": "--lf-ink",
      "role": "Primary near-black ground"
    },
    "surface": {
      "value": "#1A1C23",
      "css": "--lf-paper",
      "role": "Elevated cards and panels"
    },
    "surfaceRecessed": {
      "value": "#12141A",
      "css": "--lf-paper-2",
      "role": "Recessed surface"
    },
    "border": {
      "value": "#27272A",
      "css": "--lf-hairline",
      "role": "Rules, dividers, and borders"
    },
    "textPrimary": {
      "value": "#FFFFFF",
      "css": "--lf-bone",
      "role": "Primary text"
    },
    "textSecondary": {
      "value": "#A1A1AA",
      "css": "--lf-bone-soft",
      "role": "Secondary text"
    },
    "textTertiary": {
      "value": "#8A8A94",
      "css": "--lf-bone-dim",
      "role": "Captions and marginalia"
    },
    "signal": {
      "value": "#F97316",
      "css": "--lf-fight",
      "role": "Primary action, live state, and the point"
    },
    "signalHover": {
      "value": "#FF8330",
      "css": "--lf-fight-hover",
      "role": "Signal hover fallback"
    },
    "signalActive": {
      "value": "#E05F00",
      "css": "--lf-fight-active",
      "role": "Signal active fallback"
    },
    "support": {
      "value": "#3B82F6",
      "css": "--lf-blue",
      "role": "Supporting accent and ambient system cue"
    },
    "supportSoft": {
      "value": "#60A5FA",
      "css": "--lf-blue-soft",
      "role": "Secondary labels and accessible supporting emphasis"
    },
    "error": {
      "value": "#F87171",
      "css": "--lf-error",
      "role": "Fault and invalid state"
    },
    "success": {
      "value": "#4ADE80",
      "css": "--lf-success",
      "role": "Confirmed and valid state"
    }
  },
  "type": {
    "heading": {
      "family": "Oswald Variable",
      "fallback": "Oswald",
      "weight": 700,
      "css": "--lf-heading",
      "use": "Headlines, names, and the wordmark"
    },
    "body": {
      "family": "Barlow",
      "weights": [400, 700],
      "css": "--lf-body",
      "use": "Reading copy, lists, and controls"
    },
    "label": {
      "family": "JetBrains Mono",
      "weights": [500, 700],
      "css": "--lf-mono",
      "use": "Functional labels, dates, status, and verified facts"
    }
  },
  "spacing": {
    "base": "8px",
    "gap": "16px",
    "cardPadding": "24px",
    "sectionPadding": "clamp(64px, 8vw, 128px)"
  },
  "radius": {
    "small": "12px",
    "control": "32px",
    "card": "32px",
    "pill": "9999px"
  },
  "motion": {
    "signal": {
      "duration": "180ms",
      "easing": "cubic-bezier(0.22, 0.61, 0.36, 1)"
    },
    "settle": {
      "duration": "320ms",
      "easing": "cubic-bezier(0.22, 1, 0.36, 1)"
    },
    "rules": [
      "Many into one",
      "Weight before flash",
      "Static first paint",
      "Reduced motion is first class"
    ]
  },
  "mark": {
    "name": "The Tugboat",
    "idea": "The small craft that pulls above its size",
    "fixedColorFiles": [
      "logo/mark-white.svg",
      "logo/mark-ink.svg",
      "logo/mark-orange.svg"
    ],
    "currentColorFile": "logo/mark-currentcolor.svg",
    "minimumSize": {
      "favicon": "20px",
      "general": "32px"
    },
    "clearspace": "At least the height of the smokestack on all sides"
  },
  "contact": "hello@littlefightnyc.com",
  "footer": "Designed, Hosted and Cared For by LittleFightNYC.com"
}
